#!/usr/bin/env bash
# Commit-msg hook: validate Co-Authored-By trailers
# Ensures both trailers are present:
#   1. Co-Authored-By: <team member> <parametrization+...@gmail.com>
#   2. Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
#
# Emergency override: SKIP_TRAILER_CHECK=1 git commit ...

set -euo pipefail

if [[ "${SKIP_TRAILER_CHECK:-0}" == "1" ]]; then
    echo "WARN: Co-Authored-By trailer check skipped (SKIP_TRAILER_CHECK=1)"
    exit 0
fi

COMMIT_MSG_FILE="$1"

if [[ ! -f "$COMMIT_MSG_FILE" ]]; then
    echo "ERROR: Commit message file not found: $COMMIT_MSG_FILE"
    exit 1
fi

commit_msg=$(cat "$COMMIT_MSG_FILE")

# Load roster members from shared roster.json
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ROSTER_FILE="$REPO_ROOT/.claude/team/roster.json"

ROSTER_MEMBERS=()
if [[ -f "$ROSTER_FILE" ]]; then
    while IFS= read -r name; do
        ROSTER_MEMBERS+=("$name")
    done < <(python3 -c "import json; [print(k) for k in json.load(open('$ROSTER_FILE'))]")
else
    echo "WARN: Roster file not found at $ROSTER_FILE — skipping name validation"
    exit 0
fi

# Check for Claude trailer
claude_trailer="Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>"
if ! grep -qF "$claude_trailer" "$COMMIT_MSG_FILE"; then
    echo "ERROR: Missing required Claude Co-Authored-By trailer."
    echo ""
    echo "Every commit must include:"
    echo "  $claude_trailer"
    echo ""
    echo "Override: SKIP_TRAILER_CHECK=1 git commit ..."
    exit 1
fi

# Check for team member trailer (parametrization+...@gmail.com pattern)
member_pattern='Co-Authored-By: .* <parametrization\+.*@gmail\.com>'
if ! grep -qP "$member_pattern" "$COMMIT_MSG_FILE"; then
    echo "ERROR: Missing required team member Co-Authored-By trailer."
    echo ""
    echo "Every commit must include a trailer like:"
    echo "  Co-Authored-By: Firstname Lastname <parametrization+Firstname.Lastname@gmail.com>"
    echo ""
    echo "Override: SKIP_TRAILER_CHECK=1 git commit ..."
    exit 1
fi

# Extract the team member name from the trailer
member_line=$(grep -P "$member_pattern" "$COMMIT_MSG_FILE" | head -1)
# Extract name between "Co-Authored-By: " and " <"
member_name=$(echo "$member_line" | sed -E 's/^Co-Authored-By:\s+(.+)\s+<.+>$/\1/')

# Validate against roster
found=false
for roster_name in "${ROSTER_MEMBERS[@]}"; do
    if [[ "$member_name" == "$roster_name" ]]; then
        found=true
        break
    fi
done

if [[ "$found" != "true" ]]; then
    echo "ERROR: Co-Authored-By name '$member_name' does not match any roster member."
    echo ""
    echo "Known roster members:"
    for name in "${ROSTER_MEMBERS[@]}"; do
        echo "  - $name"
    done
    echo ""
    echo "Override: SKIP_TRAILER_CHECK=1 git commit ..."
    exit 1
fi

exit 0
