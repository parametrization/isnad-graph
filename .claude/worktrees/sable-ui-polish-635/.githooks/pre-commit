#!/usr/bin/env bash
# Pre-commit hook: validate branch ownership
# Ensures the current branch starts with the committer's {FirstInitial}.{LastName}/
# Exempt: deployments/* branches, main, and worktree branches (worktree-*)
#
# Emergency override: SKIP_BRANCH_CHECK=1 git commit ...

set -euo pipefail

if [[ "${SKIP_BRANCH_CHECK:-0}" == "1" ]]; then
    echo "WARN: Branch ownership check skipped (SKIP_BRANCH_CHECK=1)"
    exit 0
fi

branch=$(git branch --show-current 2>/dev/null || echo "")

# Detached HEAD (e.g., rebase) вҖ” allow
if [[ -z "$branch" ]]; then
    exit 0
fi

# Exempt branches: main, deployments/*, worktree-*, CEO/*
if [[ "$branch" == "main" \
   || "$branch" == deployments/* \
   || "$branch" == worktree-* \
   || "$branch" == CEO/* ]]; then
    exit 0
fi

# Extract committer name from git config (set via -c user.name=...)
committer_name=$(git config user.name 2>/dev/null || echo "")

if [[ -z "$committer_name" ]]; then
    echo "ERROR: Cannot determine committer name (git config user.name is empty)."
    echo "Ensure you are committing with: git -c user.name=\"Firstname Lastname\" ..."
    exit 1
fi

# Build expected prefix: first initial + last name
first_initial=$(echo "$committer_name" | head -c 1)
# Last name = last word of the name
last_name=$(echo "$committer_name" | awk '{print $NF}')

# Normalize diacritics for branch matching (branches use ASCII)
# Remove common diacritics: ГівҶ’o, Г©вҶ’e, ГӯвҶ’i, ГәвҶ’u, ГЎвҶ’a, ГұвҶ’n, ГјвҶ’u, Г¶вҶ’o, etc.
normalize() {
    echo "$1" | sed \
        -e 's/[ГЎГ ГўГӨГЈ]/a/g' \
        -e 's/[Г©ГЁГӘГ«]/e/g' \
        -e 's/[ГӯГ¬Г®ГҜ]/i/g' \
        -e 's/[ГіГІГҙГ¶Гө]/o/g' \
        -e 's/[ГәГ№Г»Гј]/u/g' \
        -e 's/[Гұ]/n/g' \
        -e 's/[ГҪГҝ]/y/g' \
        -e 's/[Г§]/c/g' \
        -e 's/[ГҒГҖГӮГ„Гғ]/A/g' \
        -e 's/[ГүГҲГҠГӢ]/E/g' \
        -e 's/[ГҚГҢГҺГҸ]/I/g' \
        -e 's/[Г“Г’Г”Г–Г•]/O/g' \
        -e 's/[ГҡГҷГӣГң]/U/g' \
        -e 's/[Г‘]/N/g' \
        -e 's/[ГҮ]/C/g'
}

normalized_initial=$(normalize "$first_initial")
normalized_last=$(normalize "$last_name")

expected_prefix="${normalized_initial}.${normalized_last}/"

if [[ "$branch" != ${expected_prefix}* ]]; then
    echo "ERROR: Branch ownership mismatch."
    echo "  Current branch: $branch"
    echo "  Committer:      $committer_name"
    echo "  Expected prefix: ${expected_prefix}"
    echo ""
    echo "You may only commit to branches starting with '${expected_prefix}'."
    echo "Switch to your own branch or use SKIP_BRANCH_CHECK=1 to override."
    exit 1
fi

exit 0
