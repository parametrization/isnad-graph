# =============================================================================
# isnad-graph environment configuration
# Copy to .env and fill in values. Variables marked [REQUIRED] must be set
# for production — the prod compose will refuse to start without them.
# =============================================================================

# Neo4j [REQUIRED for production]
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=change-me
NEO4J_PASSWORD=change-me

# PostgreSQL — individual vars used by prod compose [REQUIRED for production]
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_DB=isnad_graph

# PostgreSQL DSN — used by the application (constructed from individual vars in prod compose)
PG_DSN=postgresql://change-me:change-me@localhost:5432/isnad_graph

# Redis [REQUIRED for production]
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change-me

# APIs
SUNNAH_API_KEY=
KAGGLE_USERNAME=
KAGGLE_KEY=

# Paths
DATA_RAW_DIR=./data/raw
DATA_STAGING_DIR=./data/staging
DATA_CURATED_DIR=./data/curated

# CORS (JSON list of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
